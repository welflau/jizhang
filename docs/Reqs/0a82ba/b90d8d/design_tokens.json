{
  "breakpoints": {
    "mobile": "768px",
    "tablet": "1024px",
    "desktop": "1440px"
  },
  "container": {
    "maxWidth": {
      "desktop": "1440px",
      "tablet": "100%",
      "mobile": "100%"
    },
    "padding": {
      "desktop": "24px",
      "tablet": "16px",
      "mobile": "12px"
    }
  },
  "grid": {
    "columns": {
      "desktop": 24,
      "tablet": 12,
      "mobile": 6
    },
    "gutter": {
      "xs": "8px",
      "sm": "12px",
      "md": "16px",
      "lg": "24px"
    }
  },
  "spacing": {
    "responsive": {
      "desktop": "24px",
      "tablet": "16px",
      "mobile": "12px"
    },
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "xxl": "48px"
  },
  "colors": {
    "primary": "#1890ff",
    "bg": "#ffffff",
    "bgSecondary": "#f5f5f5",
    "text": "#262626",
    "textSecondary": "#8c8c8c",
    "border": "#d9d9d9"
  },
  "typography": {
    "base": "14px",
    "sm": "12px",
    "lg": "16px",
    "heading": "20px",
    "lineHeight": "1.5"
  },
  "radius": {
    "sm": "2px",
    "md": "4px",
    "lg": "8px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0, 0, 0, 0.03)",
    "md": "0 1px 8px rgba(0, 0, 0, 0.08)",
    "lg": "0 4px 16px rgba(0, 0, 0, 0.12)"
  },
  "transition": {
    "fast": "150ms",
    "base": "300ms",
    "slow": "500ms"
  }
}