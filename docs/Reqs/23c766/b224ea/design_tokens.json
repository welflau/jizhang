    "bg_primary": "#FFFFFF",
    "bg_secondary": "#F9FAFB",
    "bg_tertiary": "#F3F4F6",
    "text_primary": "#111827",
    "text_secondary": "#6B7280",
    "text_disabled": "#9CA3AF",
