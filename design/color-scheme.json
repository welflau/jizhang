  "wcag_compliance": {
    "level": "AA",
    "normal_text_minimum": 4.5,
    "large_text_minimum": 3.0,
    "notes": "All recommended text colors meet WCAG AA standards (4.5:1) on white background. Large text (18pt+ or 14pt+ bold) requires 3:1 minimum."
  },
  "usage_guidelines": {
    "text_on_white": [
      "primary-700",
      "secondary-700",
      "accent-700",
      "neutral-700"
    ],
    "text_on_dark": [
      "neutral-white",
      "primary-100",
      "secondary-100"
    ],
    "backgrounds": [
      "neutral-50",
      "neutral-100",
      "primary-50",
      "secondary-50"
    ],
    "interactive_elements": {
      "default": "primary-600",
      "hover": "primary-700",
      "active": "primary-800",
      "disabled": "neutral-300"
    },
    "borders": [
      "neutral-200",
      "neutral-300"
    ]
  },
  "css_variables": {
    "example": ":root {\n  --color-primary: #2563eb;\n  --color-success: #047857;\n  --color-error: #dc2626;\n  --color-text: #404040;\n  --color-border: #e5e5e5;\n}"
  }
